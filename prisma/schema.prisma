generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id                String             @id @default(uuid())
  name              String
  slug              String             @unique
  description       String?
  logo              String?
  website           String
  affiliateUrl      String?
  cashbackRate      String?
  cashbackType      String?
  offerCount        Int                @default(0)
  isActive          Boolean            @default(true)
  isFeatured        Boolean            @default(false)
  seoTitle          String?
  seoDescription    String?
  clicks            Int                @default(0)
  revenue           Float              @default(0.0)
  version           Int                @default(1)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activeOfferCount  Int                @default(0)
  lastImportedAt    DateTime?
  searchImpressions Int                @default(0)
  healthScore              Json?
  knowledgeDensity         Float              @default(0.0)
  visitors                 Int                @default(0)
  conversions              Int                @default(0)
  affiliatePrograms AffiliateProgram[]
  campaignLinks     CampaignLink[]
  clickEvents       ClickEvent[]
  coupons           Coupon[]
  aliases           MerchantAlias[]
  storeCategories   StoreCategory[]
  storeContents     StoreContent[]
  merchantHistories MerchantHistory[]

  @@index([slug])
  @@index([createdAt])
  @@index([isActive])
}

model Category {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  description     String?
  icon            String?
  image           String?
  isActive        Boolean         @default(true)
  isFeatured      Boolean         @default(false)
  displayOrder    Int             @default(0)
  aboutContent    String?
  faqContent      String?
  parentId        String?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  parent          Category?       @relation("CategoryChildren", fields: [parentId], references: [id])
  children        Category[]      @relation("CategoryChildren")
  coupons         Coupon[]
  storeCategories StoreCategory[]

  @@index([slug])
  @@index([isActive])
}

model StoreCategory {
  id         String   @id @default(uuid())
  storeId    String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, categoryId])
  @@index([storeId])
  @@index([categoryId])
}

model StoreContent {
  id        String           @id @default(uuid())
  storeId   String
  type      StoreContentType
  content   String
  deletedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  store     Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  revenueAttribution Float   @default(0)
  totalClicks        Int     @default(0)
  revenue            Float   @default(0.0)
  clicks             Int     @default(0)
  visitors           Int     @default(0)
  conversions        Int     @default(0)
  lastReviewed       DateTime?
  lastVerified       DateTime?

  @@unique([storeId, type])
  @@index([storeId])
}

model Coupon {
  id                 String              @id @default(uuid())
  title              String
  description        String?
  code               String?
  type               String              @default("coupon")
  discountType       String
  discountValue      String?
  affiliateUrl       String
  image              String?
  termsConditions    String?
  expiresAt          DateTime?
  isVerified         Boolean             @default(false)
  isExclusive        Boolean             @default(false)
  isFeatured         Boolean             @default(false)
  usageCount         Int                 @default(0)
  clicks             Int                 @default(0)
  displayOrder       Int                 @default(0)
  storeId            String
  bank               String?
  categoryId         String?
  version            Int                 @default(1)
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  revenueAttribution Float               @default(0)
  totalClicks        Int                 @default(0)
  totalConversions   Int                 @default(0)
  clickEvents        ClickEvent[]
  category           Category?           @relation(fields: [categoryId], references: [id])
  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaigns          AffiliateCampaign[] @relation("AffiliateCampaignToCoupon")
  collections        Collection[]        @relation("CollectionToCoupon")

  @@index([storeId])
  @@index([categoryId])
  @@index([expiresAt])
  @@index([createdAt])
}

model AffiliateNetwork {
  id        String             @id @default(uuid())
  name      String
  slug      String             @unique
  deletedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  programs  AffiliateProgram[]

  @@index([slug])
}

model AffiliateProgram {
  id             String              @id @default(uuid())
  merchantId     String
  networkId      String
  programId      String
  commissionType String
  commissionRate String
  cookieDuration Int
  status         String              @default("active")
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  campaigns      AffiliateCampaign[]
  merchant       Store               @relation(fields: [merchantId], references: [id])
  network        AffiliateNetwork    @relation(fields: [networkId], references: [id])

  @@index([merchantId])
  @@index([networkId])
}

model AffiliateCampaign {
  id             String                     @id @default(uuid())
  programId      String
  trackingUrl    String
  landingUrl     String?
  campaignName   String
  commissionRate String?
  priority       Int                        @default(0)
  active         Boolean                    @default(true)
  deletedAt      DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  program        AffiliateProgram           @relation(fields: [programId], references: [id])
  history        AffiliateCampaignHistory[]
  clickEvents    ClickEvent[]
  coupons        Coupon[]                   @relation("AffiliateCampaignToCoupon")

  @@index([programId])
}

model AffiliateCampaignHistory {
  id             String            @id @default(uuid())
  campaignId     String
  commissionRate String?
  trackingUrl    String
  effectiveFrom  DateTime          @default(now())
  effectiveTo    DateTime?
  createdAt      DateTime          @default(now())
  campaign       AffiliateCampaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId, effectiveFrom])
}

model Collection {
  id                 String    @id @default(uuid())
  name               String
  slug               String    @unique
  type               String
  seoTitle           String?
  seoDescription     String?
  content            String?
  faqContent         String?
  isIndexable        Boolean   @default(true)
  priority           Float     @default(0.5)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  revenueAttribution Float     @default(0)
  totalClicks        Int       @default(0)
  totalConversions   Int       @default(0)
  coupons            Coupon[]  @relation("CollectionToCoupon")

  @@index([slug])
  @@index([type])
}

model Banner {
  id        String    @id @default(uuid())
  imageUrl  String
  link      String
  title     String?
  isActive  Boolean   @default(true)
  order     Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
}

model Admin {
  id           String     @id @default(uuid())
  email        String     @unique
  password     String
  name         String?
  bio          String?
  profileImage String?
  socialLinks  String?
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  posts        BlogPost[]
}

model SiteSettings {
  id              String   @id @default(uuid())
  siteName        String   @default("CouponHub")
  siteTagline     String?
  siteLogo        String?
  siteDescription String?
  contactEmail    String?
  socialLinks     String?
  footerContent   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CampaignLink {
  id             String    @id @default(uuid())
  name           String
  slug           String    @unique
  destinationUrl String
  storeId        String?
  description    String?
  clicks         Int       @default(0)
  isActive       Boolean   @default(true)
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  expiresAt      DateTime?
  store          Store?    @relation(fields: [storeId], references: [id])

  @@index([slug])
  @@index([storeId])
}

model BlogPost {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  excerpt        String?
  content        String
  coverImage     String?
  seoTitle       String?
  seoDescription String?
  keywords       String?
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  authorId       String
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  author         Admin     @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([authorId])
  @@index([isPublished])
}

model Subscriber {
  id        String    @id @default(uuid())
  email     String    @unique
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model NewsArticle {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  summary     String
  sourceUrl   String
  sourceName  String?
  imageUrl    String?
  isVerified  Boolean   @default(false)
  publishedAt DateTime  @default(now())
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isVerified])
}

model AnalyticsEvent {
  id         String             @id @default(uuid())
  type       AnalyticsEventType
  source     String             @default("website")
  version    String             @default("v1")
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime           @default(now())

  @@index([type, createdAt])
  @@index([entityType, entityId])
}

model SearchConsoleMetric {
  id          String   @id @default(uuid())
  url         String
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  createdAt   DateTime @default(now())

  @@unique([url, date])
  @@index([date])
}

model AffiliatePostback {
  id               String   @id @default(uuid())
  network          String
  transactionId    String   @unique
  clickId          String?
  status           String
  saleAmount       Float    @default(0)
  commissionAmount Float    @default(0)
  currency         String   @default("USD")
  rawPayload       Json
  processed        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([network, transactionId])
  @@index([clickId])
}

model ClickEvent {
  id          String             @id @default(uuid())
  couponId    String?
  storeId     String?
  campaignId  String?
  ipAddress   String?
  userAgent   String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime           @default(now())
  campaign    AffiliateCampaign? @relation(fields: [campaignId], references: [id])
  coupon      Coupon?            @relation(fields: [couponId], references: [id])
  store       Store?             @relation(fields: [storeId], references: [id])

  @@index([couponId, createdAt])
  @@index([storeId, createdAt])
  @@index([campaignId, createdAt])
}

model AuditLog {
  id         String      @id @default(uuid())
  adminId    String
  entityType String
  entityId   String
  action     AuditAction
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime    @default(now())
  admin      Admin       @relation(fields: [adminId], references: [id])

  @@index([entityType, entityId])
  @@index([adminId, createdAt])
}

model ImportJob {
  id               String          @id @default(uuid())
  status           ImportStatus    @default(PENDING)
  startedAt        DateTime?
  finishedAt       DateTime?
  error            Json?
  createdAt        DateTime        @default(now())
  aiComplete       Int             @default(0)
  aiPending        Int             @default(0)
  avgQuality       Float           @default(0.0)
  duplicates       Int             @default(0)
  processingTimeMs Int?
  published        Int             @default(0)
  rejected         Int             @default(0)
  source           String          @default("csv")
  totalRows        Int             @default(0)
  validRows        Int             @default(0)
  apiLatencyMs     Int?
  connectorVersion String?
  pagesFetched     Int             @default(0)
  recordsFetched   Int             @default(0)
  importedOffers   ImportedOffer[]
}

model ImportedOffer {
  id                   String    @id @default(uuid())
  importJobId          String
  schemaVersion        String    @default("v1")
  source               String
  sourceId             String?
  rawData              Json
  normalizedData       Json
  completenessScore    Float     @default(0.0)
  validationScore      Float     @default(0.0)
  confidenceScore      Float     @default(0.0)
  freshnessScore       Float     @default(0.0)
  merchantMatchScore   Float     @default(0.0)
  duplicateRisk        Float     @default(0.0)
  finalQualityScore    Float     @default(0.0)
  validationErrors     Json?
  status               String    @default("pending")
  aiEnrichedData       Json?
  aiStatus             String    @default("none")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  resolutionConfidence Json?
  resolutionReason     String?
  suggestedStoreId     String?
  resolutionSource     String?
  resolvedStoreId      String?
  importJob            ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([status])
  @@index([source, sourceId])
  @@index([aiStatus])
}

model MerchantAlias {
  id              String    @id @default(uuid())
  merchantId      String
  alias           String
  normalizedAlias String
  source          String
  confidence      Int       @default(100)
  approvedBy      String?
  approvedAt      DateTime?
  lastSeenAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  merchant        Store     @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, alias])
  @@index([alias])
  @@index([normalizedAlias])
}

model AdminNotification {
  id        String            @id @default(uuid())
  title     String
  message   String
  level     NotificationLevel @default(INFO)
  source    String            @default("system")
  isRead    Boolean           @default(false)
  link      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([isRead, createdAt])
  @@index([source])
}

model IntelligenceTask {
  id            String                 @id @default(uuid())
  event         IntelligenceEvent
  entityType    String
  entityId      String
  workerName    String
  status        IntelligenceTaskStatus @default(PENDING)
  priority      Int                    @default(0)
  attempts      Int                    @default(0)
  promptVersion String
  workerVersion String
  model         String
  settings      Json?
  inputSnapshot Json
  generatedData Json?
  error         Json?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([status, priority, createdAt])
  @@index([entityType, entityId])
  @@index([workerName])
}

model KnowledgeNode {
  id            String          @id @default(uuid())
  type          NodeType
  entityId      String?
  name          String
  metadata      Json?
  source        String?
  confidence    Int             @default(100)
  createdBy     String?
  verifiedAt    DateTime?
  outgoingEdges KnowledgeEdge[] @relation("SourceNode")
  incomingEdges KnowledgeEdge[] @relation("TargetNode")

  @@index([type])
  @@index([entityId])
}

model KnowledgeEdge {
  id            String        @id @default(uuid())
  sourceId      String
  targetId      String
  type          EdgeType
  weight        Float         @default(1.0)
  metadata      Json?
  effectiveFrom DateTime      @default(now())
  effectiveTo   DateTime?
  source        String?
  confidence    Int           @default(100)
  sourceNode    KnowledgeNode @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  targetNode    KnowledgeNode @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
  @@index([sourceId, targetId, type])
}

model Opportunity {
  id                String            @id @default(uuid())
  type              OpportunityType
  subType           String?
  title             String
  engineVersion     String            @default("v1")
  inputSnapshot     Json?
  reasoning         String?
  recommendation    String?
  confidence        Int               @default(0)
  status            OpportunityStatus @default(GENERATED)
  targetEntityId    String
  nodeId            String?
  decision          Decision?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Decision {
  id             String      @id @default(uuid())
  opportunityId  String      @unique
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  decision       String      // APPROVED, REJECTED, IMPLEMENTED
  owner          String?     // User ID or AI Agent ID
  executedAt     DateTime?
  expectedImpact String?
  actualImpact   String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum StoreContentType {
  ABOUT
  FAQ
  BUYING_GUIDE
  RETURNS
  SHIPPING
  PAYMENTS
  STUDENT
  SALE
  REFUND
  EXCHANGE
  WARRANTY
  GIFT_CARDS
  MILITARY_DISCOUNT
  CORPORATE_DISCOUNT
  LOYALTY_PROGRAM
  BLACK_FRIDAY
  PRIME_DAY
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AnalyticsEventType {
  COUPON_CLICK
  STORE_VIEW
  SEARCH
  NEWSLETTER_SIGNUP
  OFFER_IMPORTED
  OFFER_PUBLISHED
  OFFER_INDEXED
  OFFER_CLICKED
  OFFER_CONVERTED
}

enum NotificationLevel {
  INFO
  WARNING
  ERROR
  SUCCESS
}

enum IntelligenceEvent {
  COUPON_PUBLISHED
  MERCHANT_UPDATED
  COLLECTION_CREATED
}

enum IntelligenceTaskStatus {
  PENDING
  PROCESSING
  PENDING_REVIEW
  APPROVED
  APPLIED
  REJECTED
  FAILED
}

enum NodeType {
  MERCHANT
  CATEGORY
  BANK
  BRAND
  FESTIVAL
  EVENT
  GUIDE
  FAQ
  POLICY
  FEATURE
}

enum EdgeType {
  HAS_GUIDE
  HAS_CATEGORY
  HAS_EVENT
  HAS_BANK
  SUPPORTED_BY
  SELLS
  RELATED_TO
  HAS_POLICY
  HAS_FEATURE
}

enum OpportunityType {
  COVERAGE
  FRESHNESS
  TRUST
  SEO
  CRO
  REVENUE
  INTERNAL_LINKING
  SEASONAL
  MERCHANT
  KNOWLEDGE
}

enum OpportunityStatus {
  GENERATED
  TRIAGED
  APPROVED
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

model MerchantHistory {
  id          String   @id @default(uuid())
  storeId     String
  date        DateTime
  title       String
  description String?
  type        String   @default("milestone")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([date])
}

model Learning {
  id             String      @id @default(uuid())
  pattern        String      // "Adding FAQ to electronics merchants increases CTR"
  confidence     Int         // 0-100
  evidence       Json        // Array of supporting Decision IDs or raw data
  impact         String      // e.g., "+31% RPIP"
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}
